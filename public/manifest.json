{
  "manifest_version": 3,
  "name": "Ergo Names Extension",
  "version": "0.1.0",
  "description": "A chrome extension to resolve Ergo Names NFT ownership.",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Ergo Names Resolver",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ]
}